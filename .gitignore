data/caddy/
recordings/
recordings-encrypted/

# Build artefacts
.dockerignore.local

# ─────────────────────────────────────────────────────────────
# Telephony / media artefacts (large, ephemeral, often PHI)
# ─────────────────────────────────────────────────────────────
# Captured pcap / SIP traces from local dev
*.pcap
*.pcapng
captures/
homer-data/

# Local recordings (NEVER commit — possible PHI even in dev)
*.wav
*.mp3
*.opus
*.m4a
*.flac
# Synthetic test fixtures are explicitly allowed under contracts/fixtures/
!contracts/fixtures/**/*.wav
!contracts/fixtures/**/*.opus
!contracts/fixtures/**/*.flac

# Asterisk runtime
asterisk-spool/
asterisk-recordings/
asterisk-log/

# Kamailio runtime
kamailio-data/

# ─────────────────────────────────────────────────────────────
# Secrets / env / credentials — NEVER commit
# ─────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.*.example
!.env.template
!.env.sample

*.pem
*.key
*.crt
*.csr
*.p12
*.pfx
*.jks

# Caddy storage / cert cache
caddy-data/
caddy-config/

# Vault dev unseal artefacts (local only)
vault-keys.json
unseal-keys.json
.vault-token

# AWS / GCP / Azure local creds (defence in depth)
.aws/
.gcp/
.azure/
*.credentials
service-account*.json
gcp-key*.json

# SSH
id_rsa
id_ed25519
*.pub

# Terraform / OpenTofu (if used for infra)
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Pulumi
Pulumi.*.yaml
!Pulumi.yaml

# Kubernetes / Helm
charts/*.tgz
.helm/
kubeconfig
*.kubeconfig

