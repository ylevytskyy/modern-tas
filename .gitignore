.docker/
.docker-data/
docker-data/
volumes/
.compose-data/

# Common per-service data dirs if mounted at repo root in dev:
data/postgres/
data/redis/
data/nats/
data/minio/
data/temporal/
data/homer/
data/loki/
data/grafana/
data/prometheus/
