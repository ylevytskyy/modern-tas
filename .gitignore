# ─────────────────────────────────────────────────────────────
# Project-specific
# ─────────────────────────────────────────────────────────────
# PoT scratch directories (Phase 0 throwaway code)
pot/scratch/
.pot-local/

# Subagent-loop intermediate artifacts (planner/verifier rounds)
.scratch/

# Generated golden fixtures we DO want tracked live under contracts/fixtures/.
# Per-developer overrides do not.
contracts/fixtures/**/.local/

# Local seed dumps (may contain real data after a CRM smoke test)
seeds/local/
seeds/*.local.sql
seeds/*.local.json

