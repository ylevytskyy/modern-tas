# ─────────────────────────────────────────────────────────────
# Prisma 6
# ─────────────────────────────────────────────────────────────
# Keep the schema and migrations; ignore generated client artefacts
prisma/.env
prisma/dev.db
prisma/dev.db-journal
prisma/migrations/**/migration_lock.toml.bak

# Generated client lives in node_modules/.prisma — already ignored.
# If a custom output path is configured under packages/db/client, ignore it:
packages/db/client/
**/generated/prisma/

# ─────────────────────────────────────────────────────────────
# OpenAPI / AsyncAPI / contract generation
# ─────────────────────────────────────────────────────────────
contracts/.cache/
contracts/.tmp/
**/openapi-generated/
**/asyncapi-generated/
.spectral-cache/

