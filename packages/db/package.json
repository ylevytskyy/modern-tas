{
  "name": "@tas/db",
  "version": "0.0.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./src/schema/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint TBD'",
    "test": "vitest run",
    "migrate:gen": "drizzle-kit generate:pg --config drizzle.config.ts",
    "migrate": "tsx src/migrate.ts",
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "drizzle-orm": "0.30.4",
    "postgres": "3.4.4"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "10.9.0",
    "@types/node": "^24",
    "drizzle-kit": "0.20.14",
    "testcontainers": "10.9.0",
    "tsx": "4.7.1",
    "typescript": "5.4.2",
    "vitest": "1.4.0"
  }
}
