# S8 — Caddy 2.10+ on-demand TLS with `permission http` ask endpoint.
#
# Hazard ADR-0019 names: an unknown-SNI flood (certmagic #174) where the
# `ask` endpoint is checked *after* storage lookup, causing storage thrash.
# This config validates the opposite: `ask` is checked first, declined
# domains are LRU-cached, and storage activity stays bounded.
#
# Critical knobs:
#   - `tls internal`        : use Caddy's local CA so we never hit real LE.
#   - `on_demand_tls.ask`   : Caddy calls permission:8080?domain=<sni> before
#                             any storage lookup or cert issuance attempt.
#   - `servers { metrics }` : exposes Prometheus metrics on admin :2019.
#   - `storage file_system` : explicit file-system backend at /data/caddy
#                             so test-runner can count files / observe I/O.

{
	admin :2019
	auto_https disable_redirects

	on_demand_tls {
		ask http://permission:8080/
	}

	servers {
		metrics
	}

	storage file_system {
		root /data/caddy
	}

	log default {
		output stdout
		format json
		level INFO
	}
}

# Catch-all HTTPS — any SNI lands here; whether a cert is issued is decided
# by the `ask` endpoint above.
:443 {
	tls {
		on_demand
		issuer internal
	}

	respond "ok" 200
}

# Plaintext :80 — used by k6 only for sanity-check pings, not for the flood.
:80 {
	respond "caddy ok" 200
}
