# apps/api env template — copy to .env or export in shell before `pnpm --filter @tas/api run dev`.
#
# tsx does NOT auto-load .env. Until the dev script adopts `--env-file=.env`
# (or main.ts imports dotenv/config), these must be exported in the launching
# shell. See poc/smoke-chunk4.md §"Operational gotchas".

# Required — must match the worker's value (workflow activity sends it as X-Internal-Token).
INTERNAL_API_TOKEN=replace-with-output-of-openssl-rand-hex-32

# Required.
DATABASE_URL=postgres://tas:tas@localhost:5432/tas

# Optional — default 'poc-only-not-prod'; signs operator JWTs.
APP_JWT_SECRET=poc-only-not-prod

# Optional — default http://localhost:3001; CORS allowed origin for apps/web.
WEB_ORIGIN=http://localhost:3001

# Optional — default 3000.
PORT=3000
